{
  "name": "react-native-telephone",
  "version": "2.1.0",
  "description": "Zero-dependency React Native international phone input with per-country masking and validation (runs on web via react-native-web)",
  "keywords": [
    "react-native",
    "react-native-web",
    "react",
    "phone",
    "telephone",
    "phone-input",
    "international",
    "e164",
    "form",
    "component"
  ],
  "author": "Ivan Stepanian <iv.stpn@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iv-stpn/react-native-telephone.git"
  },
  "type": "module",
  "exports": {
    "./phone-input": {
      "types": "./dist/components/PhoneInput.d.ts",
      "import": "./dist/components/PhoneInput.js",
      "require": "./dist/components/PhoneInput.cjs"
    },
    "./country-picker": {
      "types": "./dist/components/CountryPicker.d.ts",
      "import": "./dist/components/CountryPicker.js",
      "require": "./dist/components/CountryPicker.cjs"
    },
    "./phone": {
      "types": "./dist/utils/phone.d.ts",
      "import": "./dist/utils/phone.js",
      "require": "./dist/utils/phone.cjs"
    },
    "./options": {
      "types": "./dist/utils/options.d.ts",
      "import": "./dist/utils/options.js",
      "require": "./dist/utils/options.cjs"
    },
    "./flags": {
      "types": "./dist/utils/flags.d.ts",
      "import": "./dist/utils/flags.js",
      "require": "./dist/utils/flags.cjs"
    },
    "./emoji": {
      "types": "./dist/utils/emoji.d.ts",
      "import": "./dist/utils/emoji.js",
      "require": "./dist/utils/emoji.cjs"
    },
    "./styles": {
      "types": "./dist/components/styles.d.ts",
      "import": "./dist/components/styles.js",
      "require": "./dist/components/styles.cjs"
    },
    "./types": {
      "types": "./dist/components/types.d.ts",
      "import": "./dist/components/types.js",
      "require": "./dist/components/types.cjs"
    },
    "./codes": {
      "types": "./dist/codes.d.ts",
      "import": "./dist/codes.js",
      "require": "./dist/codes.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationMap false",
    "prepare": "node .husky/install.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "typecheck": "tsc --noEmit && tsc --noEmit -p demo/tsconfig.json && tsc --noEmit -p src/__tests__/tsconfig.json",
    "prepublishOnly": "bun run build && bun run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && bun run typecheck && changeset publish",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite --config demo/vite.config.ts build --base /react-native-telephone/"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "husky": "^9",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@iv-stpn/biome-config": "1.2.13",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/bun": "latest",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "biome-drizzle-best-practices-plugin": "2.0.0",
    "biome-one-liner-plugin": "1.3.3",
    "biome-react-best-practices-plugin": "2.0.0",
    "biome-typescript-best-practices-plugin": "1.2.1",
    "jsdom": "^29",
    "react": "^19",
    "react-dom": "^19",
    "react-native": "0.86.0",
    "react-native-web": "^0.21",
    "tsup": "^8",
    "typescript": "^7",
    "vite": "^8",
    "vitest": "^4"
  },
  "dependencies": {
    "country-data-ts": "^0.1.0"
  }
}
