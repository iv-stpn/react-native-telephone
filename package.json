{
  "name": "react-native-telephone",
  "version": "0.4.0",
  "description": "Zero-dependency React Native international phone input with per-country masking and validation (runs on web via react-native-web)",
  "keywords": [
    "react-native",
    "react-native-web",
    "react",
    "phone",
    "telephone",
    "phone-input",
    "international",
    "e164",
    "form",
    "component"
  ],
  "author": "Ivan Stepanian <iv.stpn@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iv-stpn/react-native-telephone.git"
  },
  "type": "module",
  "main": "./dist/phone-input.cjs",
  "module": "./dist/phone-input.js",
  "react-native": "./dist/phone-input.js",
  "types": "./dist/phone-input.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/phone-input.d.ts",
        "default": "./dist/phone-input.js"
      },
      "require": {
        "types": "./dist/phone-input.d.cts",
        "default": "./dist/phone-input.cjs"
      }
    },
    "./country-picker": {
      "import": {
        "types": "./dist/country-picker.d.ts",
        "default": "./dist/country-picker.js"
      },
      "require": {
        "types": "./dist/country-picker.d.cts",
        "default": "./dist/country-picker.cjs"
      }
    },
    "./phone": {
      "import": {
        "types": "./dist/phone.d.ts",
        "default": "./dist/phone.js"
      },
      "require": {
        "types": "./dist/phone.d.cts",
        "default": "./dist/phone.cjs"
      }
    },
    "./options": {
      "import": {
        "types": "./dist/options.d.ts",
        "default": "./dist/options.js"
      },
      "require": {
        "types": "./dist/options.d.cts",
        "default": "./dist/options.cjs"
      }
    },
    "./flags": {
      "import": {
        "types": "./dist/flags.d.ts",
        "default": "./dist/flags.js"
      },
      "require": {
        "types": "./dist/flags.d.cts",
        "default": "./dist/flags.cjs"
      }
    },
    "./emoji": {
      "import": {
        "types": "./dist/emoji.d.ts",
        "default": "./dist/emoji.js"
      },
      "require": {
        "types": "./dist/emoji.d.cts",
        "default": "./dist/emoji.cjs"
      }
    },
    "./styles": {
      "import": {
        "types": "./dist/styles.d.ts",
        "default": "./dist/styles.js"
      },
      "require": {
        "types": "./dist/styles.d.cts",
        "default": "./dist/styles.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    },
    "./codes": {
      "import": {
        "types": "./dist/codes.d.ts",
        "default": "./dist/codes.js"
      },
      "require": {
        "types": "./dist/codes.d.cts",
        "default": "./dist/codes.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "typecheck": "tsc --noEmit && tsc --noEmit -p demo/tsconfig.json && tsc --noEmit -p src/__tests__/tsconfig.json",
    "prepublishOnly": "bun run build && bun run typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && bun run typecheck && changeset publish",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite --config demo/vite.config.ts build --base /react-native-telephone/"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "biome-one-liner-plugin": "1.3.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native": "0.76.5",
    "react-native-web": "^0.21.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "country-data-ts": "^0.1.0"
  }
}
